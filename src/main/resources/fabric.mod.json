{
  "schemaVersion": 1,
  "id": "removewardeneffect",
  "version": "${version}",

  "name": "Remove Warden Darkness",
  "description": "Removes Warden's darkness effect",
  "authors": [
    "OneSaw"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },

  "license": "MIT",
  "icon": "assets/removewardeneffect/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "net.onesaw.removewardeneffect.DarknessRemover"
    ]
  },

  "depends": {
    "fabricloader": "${loader_version_range}",
    "fabric-api": "${fabric_api_version_range}",
    "minecraft": "${minecraft_version_range}",
    "java": ">=25"
  }
}
